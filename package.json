{
  "name": "ecommerce",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["client", "server"],
  "scripts": {
    "dev": "concurrently -n server,client -c green,cyan --kill-others-on-fail \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "dev:fresh": "npm run clean && npm run dev",
    "db:init": "npm run db:init --workspace=server",
    "db:seed": "npm run db:seed --workspace=server",
    "clean": "npm run clean --workspace=client"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
